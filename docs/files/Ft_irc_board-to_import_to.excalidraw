    {
      "id": "1MdeAt3fncCe9glqk3272",
      "type": "text",
      "x": -5442.143341776065,
      "y": -1702.0458985805808,
      "width": 326.41380357847873,
      "height": 28.250198713232745,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "dotted",
      "roughness": 0,
      "opacity": 70,
      "groupIds": [],
      "frameId": null,
      "index": "b4S",
      "roundness": null,
      "seed": 1897440551,
      "version": 245,
      "versionNonce": 684881225,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1761135933288,
      "link": null,
      "locked": false,
      "text": "If you keep events = POLLIN, but there’s no data arriving,\npoll() will simply sleep until the kernel receives something.",
      "fontSize": 11.300079485293098,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If you keep events = POLLIN, but there’s no data arriving,\npoll() will simply sleep until the kernel receives something.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "WlwLQbJ-nxvegTYBXInUy",
