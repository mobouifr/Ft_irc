      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "7c_sOrpwzaJ5o5iRyALpK",
      "originalText": "Holds incoming data from network until your program calls recv(). Acts like a mailbox.",
