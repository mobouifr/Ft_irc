      "updated": 1761074481944,
      "link": null,
      "locked": false,
      "text": "Holds data from send() until it can be transmitted\nover the network. Kernel handles segmentation,\nretransmissions, and Nagle algorithm.",
      "fontSize": 8.125424663652188,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "HwuG6mLrDPBS2n0DYOZRq",
      "originalText": "Holds data from send() until it can be transmitted over the network. Kernel handles segmentation, retransmissions, and Nagle algorithm.",
      "autoResize": true,
      "lineHeight": 1.25
    },
