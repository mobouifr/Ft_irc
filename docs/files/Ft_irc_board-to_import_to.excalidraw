      "versionNonce": 1448676981,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1761074481943,
      "link": null,
      "locked": false,
      "text": "When something happens on any\nwatched FD, poll() returns and the\nkernel writes which events happened\ninto revents. Your loop must then\ninspect revents (bitmask) to decide\nwhat to do.",
      "fontSize": 33.42160456621657,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "7zUT6rmD5gxFuOzsBEKFw",
      "originalText": "When something happens on any watched FD, poll() returns and the kernel writes which events happened into revents. Your loop must then inspect revents (bitmask) to decide what to do.",
      "autoResize": true,
      "lineHeight": 1.25
    },
