    },
    {
      "id": "cUgF7ditv9-aOiAMojblA",
      "type": "rectangle",
      "x": -4133.847504571994,
      "y": -2078.174084520008,
      "width": 1163.0427136063515,
      "height": 318.394959611755,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#f8f9fa",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
