    {
      "id": "ULgbv4LFnJTEafDw7C8K7",
      "type": "text",
      "x": -5897.4769461333135,
      "y": -1443.0722136506151,
      "width": 686.9393310546875,
      "height": 25,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "#96f2d7",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
