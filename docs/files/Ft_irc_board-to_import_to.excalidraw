      "isDeleted": false,
      "boundElements": [],
      "updated": 1761121647887,
      "link": null,
      "locked": false,
      "text": "The kernel assigns the socket a local IP and port.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The kernel assigns the socket a local IP and port.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "cRtAM_lSeaimtXGm9aXqb",
      "type": "text",
      "x": -2652.771693001272,
      "y": -1896.14353661527,
      "width": 588.3851928710938,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ced4da",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 30,
      "groupIds": [],
      "frameId": null,
      "index": "b3U",
      "roundness": null,
      "seed": 1592948,
      "version": 2,
      "versionNonce": 50741620,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1761121647887,
      "link": null,
      "locked": false,
      "text": "That’s how the kernel knows which incoming packets belong to this socket.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "That’s how the kernel knows which incoming packets belong to this socket.",
      "autoResize": true,
      "lineHeight": 1.25
    },
