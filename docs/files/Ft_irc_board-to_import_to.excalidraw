      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "⚙️ 2. What happens when you call socket()?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "AfGlMyo-yKae40USOHKaC",
      "type": "text",
      "x": -2480.912205098603,
      "y": -2629.100223969163,
      "width": 365.0567626953125,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ced4da",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 30,
      "groupIds": [],
      "frameId": null,
      "index": "b3L",
      "roundness": null,
      "seed": 1715579252,
      "version": 2,
      "versionNonce": 1954536268,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1761121613922,
      "link": null,
      "locked": false,
      "text": "int fd = socket(AF_INET, SOCK_STREAM, 0);",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "int fd = socket(AF_INET, SOCK_STREAM, 0);",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "KDcvZIobAGgInSEqlhL1t",
      "type": "text",
      "x": -2444.200077413056,
      "y": -2569.100223969163,
      "width": 291.63250732421875,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ced4da",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 30,
      "groupIds": [],
      "frameId": null,
      "index": "b3M",
      "roundness": null,
      "seed": 1461639116,
      "version": 2,
      "versionNonce": 2021085044,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1761121613922,
      "link": null,
      "locked": false,
      "text": "The kernel allocates a socket object.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The kernel allocates a socket object.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "AZJ7VawuVdTEClmxXj7eS",
      "type": "text",
      "x": -2506.0722392782905,
      "y": -2509.100223969163,
      "width": 415.3768310546875,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ced4da",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 30,
      "groupIds": [],
      "frameId": null,
      "index": "b3N",
      "roundness": null,
      "seed": 1353997044,
      "version": 2,
      "versionNonce": 1761513932,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1761121613922,
      "link": null,
      "locked": false,
      "text": "It initializes it as a TCP endpoint (SOCK_STREAM).",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It initializes it as a TCP endpoint (SOCK_STREAM).",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "sZwKMz_TDCJ3p3FMkNcY8",
      "type": "text",
      "x": -2402.592037557099,
      "y": -2449.100223969163,
      "width": 208.4164276123047,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ced4da",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 30,
      "groupIds": [],
      "frameId": null,
      "index": "b3O",
      "roundness": null,
      "seed": 126484044,
      "version": 2,
      "versionNonce": 423969012,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1761121613922,
      "link": null,
      "locked": false,
      "text": "It’s in the CLOSED state.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It’s in the CLOSED state.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "CnzFp30-YX-X11lfK9qAt",
      "type": "text",
      "x": -2449.0161021933295,
      "y": -2389.100223969163,
      "width": 301.2645568847656,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ced4da",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 30,
      "groupIds": [],
      "frameId": null,
      "index": "b3P",
      "roundness": null,
      "seed": 215276660,
      "version": 2,
      "versionNonce": 2036496460,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1761121613922,
      "link": null,
      "locked": false,
      "text": "It has no local or remote address yet.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It has no local or remote address yet.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "iWACLVWpVC1FB1dT8qLfP",
      "type": "text",
      "x": -2512.5282634482123,
      "y": -2329.100223969163,
      "width": 428.28887939453125,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ced4da",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 30,
      "groupIds": [],
      "frameId": null,
      "index": "b3Q",
      "roundness": null,
      "seed": 2093765836,
      "version": 2,
      "versionNonce": 509149812,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1761121613922,
      "link": null,
      "locked": false,
      "text": "So far, it’s just a handle to a potential TCP endpoint.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "So far, it’s just a handle to a potential TCP endpoint.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "M0odDzbCRjKmlBWaeF7jg",
      "type": "text",
      "x": -2453.49690509844,
      "y": -2046.14353661527,
      "width": 189.8356170654297,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ced4da",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 30,
      "groupIds": [],
      "frameId": null,
      "index": "b3R",
      "roundness": null,
      "seed": 53937612,
      "version": 2,
      "versionNonce": 1731265228,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1761121647887,
      "link": null,
      "locked": false,
      "text": "🏠 3. Then you bind() it",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "🏠 3. Then you bind() it",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "saZdNQ8ala_dmdrxy2Fa1",
      "type": "text",
      "x": -2530.6194408040064,
      "y": -2016.14353661527,
      "width": 344.0806884765625,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ced4da",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 30,
      "groupIds": [],
      "frameId": null,
      "index": "b3S",
      "roundness": null,
      "seed": 872287476,
      "version": 2,
      "versionNonce": 577658868,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1761121647887,
      "link": null,
      "locked": false,
      "text": "bind(fd, {AF_INET, port, addr}, sizeof(...));",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "bind(fd, {AF_INET, port, addr}, sizeof(...));",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "cAeGYU5JqVYWvcunAFLb7",
      "type": "text",
      "x": -2557.3794963459986,
      "y": -1956.14353661527,
      "width": 397.6007995605469,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ced4da",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 30,
      "groupIds": [],
