      "seed": 1272766899,
      "version": 1519,
      "versionNonce": 548771099,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1761074481943,
      "link": null,
      "locked": false,
      "text": "poll() watches many sockets and tells your code which sockets changed state (readable/writable/error). \nYour server then reacts: accept new connections, recv() incoming bytes, or send() buffered replies \n— all without blocking a single client.",
      "fontSize": 41.777005707770705,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "6MRjd4-4pouWFclNj2Ieh",
      "originalText": "poll() watches many sockets and tells your code which sockets changed state (readable/writable/error). \nYour server then reacts: accept new connections, recv() incoming bytes, or send() buffered replies \n— all without blocking a single client.",
      "autoResize": true,
      "lineHeight": 1.25
    },
