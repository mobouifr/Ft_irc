      "link": null,
      "locked": false,
      "text": "int fd = socket()\nsend(fd, data) → copy data to kernel buf \nrecv(fd, buf)   ←  copy data from kernel buf",
      "fontSize": 10.22393733584772,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "int fd = socket()\nsend(fd, data) → copy data to kernel buf \nrecv(fd, buf)   ←  copy data from kernel buf",
      "autoResize": true,
      "lineHeight": 1.25
    },
