    {
      "id": "4QuscMhQhaRWVS0ZzYT6G",
      "type": "text",
      "x": -5978.975778587866,
      "y": -2919.733382884987,
      "width": 795.7632446289062,
      "height": 245,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#f8f9fa",
