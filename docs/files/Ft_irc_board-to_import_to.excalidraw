      "isDeleted": false,
      "boundElements": [],
      "updated": 1761134558792,
      "link": null,
      "locked": false,
      "text": "A socket is writable when the kernel’s send buffer has space available.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "WlwLQbJ-nxvegTYBXInUy",
      "originalText": "A socket is writable when the kernel’s send buffer has space available.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "2l232jCPCAc3U0oe7GLIf",
      "type": "ellipse",
      "x": -5407.943808755458,
      "y": -1458.744676801575,
      "width": 209.77653452816412,
      "height": 57.211824229970716,
      "angle": 0,
      "strokeColor": "#ff8787",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4W",
      "roundness": {
        "type": 2
      },
      "seed": 817071047,
      "version": 82,
      "versionNonce": 1389809353,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1761134531658,
      "link": null,
      "locked": false
    },
    {
      "id": "Jdqv3zlisgURBKSrMuu_O",
      "type": "text",
      "x": -5963.591519638082,
      "y": -1365.691316070422,
      "width": 573.3880500292735,
      "height": 55.92943601336084,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
