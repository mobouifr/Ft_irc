      "seed": 186453129,
      "version": 112,
      "versionNonce": 1870917417,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1761134686917,
      "link": null,
      "locked": false,
      "text": "For most connected TCP sockets,\nthe send buffer is almost always ready (i.e. not full),\nunless you’re writing huge amounts of data faster than the network can send.",
      "fontSize": 14.914516270229559,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "For most connected TCP sockets,\nthe send buffer is almost always ready (i.e. not full),\nunless you’re writing huge amounts of data faster than the network can send.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "FNQHY2BpCdbPdUp_ttrdA",
      "type": "text",
      "x": -5347.524766411394,
      "y": -1117.0569822932407,
      "width": 177.1767480558961,
      "height": 10.806105695698298,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 70,
      "groupIds": [],
      "frameId": null,
      "index": "b4f",
      "roundness": null,
      "seed": 1573567593,
      "version": 474,
      "versionNonce": 255399815,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1761135602138,
      "link": null,
      "locked": false,
      "text": "even if you have nothing to actually send.",
      "fontSize": 8.644884556558642,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "even if you have nothing to actually send.",
      "autoResize": true,
      "lineHeight": 1.25
    },
