      "boundElements": [],
      "updated": 1761208877818,
      "link": null,
      "locked": false,
      "text": "struct sock {            // the TCB-like object for TCP\n    uint32_t local_ip;\n    uint16_t local_port;\n    uint32_t remote_ip;\n    uint16_t remote_port;\n    uint32_t snd_nxt, rcv_nxt;   // seq numbers\n    buffer_t send_buf;           // bytes waiting to go\n    buffer_t recv_buf;           // bytes waiting for user\n    enum tcp_state state;        // SYN_SENT, ESTABLISHED, ...\n    // timers, cwnd, etc.\n};",
      "fontSize": 2.42741218235478,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "struct sock {            // the TCB-like object for TCP\n    uint32_t local_ip;\n    uint16_t local_port;\n    uint32_t remote_ip;\n    uint16_t remote_port;\n    uint32_t snd_nxt, rcv_nxt;   // seq numbers\n    buffer_t send_buf;           // bytes waiting to go\n    buffer_t recv_buf;           // bytes waiting for user\n    enum tcp_state state;        // SYN_SENT, ESTABLISHED, ...\n    // timers, cwnd, etc.\n};",
      "autoResize": true,
      "lineHeight": 1.25
    }
